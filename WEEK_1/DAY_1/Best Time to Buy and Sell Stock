class Solution {
    public int maxProfit(int[] prices) {
        int minPrice = Integer.MAX_VALUE;
        int profit = 0;
        for(int price : prices) {
            if(price < minPrice) {
                minPrice = price;
            }else if(profit < price - minPrice) {
                profit = price - minPrice;
            }
        }        
        
        return profit;
    }
}